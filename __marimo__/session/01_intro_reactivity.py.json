          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"running-as-a-script\">Running as a script</h2>\n<span class=\"paragraph\">marimo notebooks are plain Python files:</span>\n<div class=\"language-bash codehilite\"><pre><span></span><code>marimo<span class=\"w\"> </span>edit<span class=\"w\">   </span>01_intro_reactivity.py<span class=\"w\">          </span><span class=\"c1\"># interactive editor</span>\nmarimo<span class=\"w\"> </span>run<span class=\"w\">    </span>01_intro_reactivity.py<span class=\"w\">          </span><span class=\"c1\"># read-only app</span>\npython<span class=\"w\">        </span>01_intro_reactivity.py<span class=\"w\">          </span><span class=\"c1\"># plain script (n=slider default)</span>\npython<span class=\"w\">        </span>01_intro_reactivity.py<span class=\"w\"> </span>--n<span class=\"w\"> </span><span class=\"m\">20</span><span class=\"w\">   </span><span class=\"c1\"># pass n as argument \u2192 prints sum</span>\nmarimo<span class=\"w\"> </span>check<span class=\"w\">  </span>01_intro_reactivity.py<span class=\"w\">          </span><span class=\"c1\"># lint</span>\n</code></pre></div>\n<span class=\"paragraph\">In script mode the slider is ignored \u2014 <code>--n</code> sets the value and the sum is printed.</span></span>"
          }
        }
      ],
      "console": []
    },
